    // Renderizar cada grid
    function renderNoticias(categoria, containerId) {
        const container = document.getElementById(containerId);
        if (!container) return;
        const items = noticias[categoria];
        if (!items || items.length === 0) {
            container.innerHTML = `<div class="empty-msg"><i class="fas fa-newspaper"></i> No hay noticias disponibles en este momento.</div>`;
            return;
        }
        
        let html = '';
        items.forEach(nota => {
            // Badge destacado si existe (solo para alguna de local)
            let featuredHtml = '';
            if (categoria === 'local' && nota.destacada) {
                featuredHtml = `<div class="featured-badge"><i class="fas fa-star"></i> Destacada</div>`;
            }
            html += `
                <article class="news-card">
                    <div class="card-img" style="background-image: url('${nota.imagen}');"></div>
                    <div class="card-content">
                        ${featuredHtml}
                        <div class="card-category"><i class="fas fa-tag"></i> ${nota.categoria}</div>
                        <h3 class="card-title">${nota.titulo}</h3>
                        <p class="card-desc">${nota.descripcion}</p>
                        <div class="card-date"><i class="far fa-calendar-alt"></i> ${nota.fecha}</div>
                    </div>
                </article>
            `;
        });
        container.innerHTML = html;
    }

    // Inicializar todas las secciones
    function cargarTodasLasNoticias() {
        renderNoticias('local', 'localGrid');
        renderNoticias('paraguay', 'paraguayGrid');
        renderNoticias('mundo', 'mundoGrid');
    }

    // ---------------- CLIMA: simulación realista para Nueva Asunción (Presidente Hayes) ----------------
    // Dado que es una página estática para GitHub, usamos una simulación de clima actual basada en la fecha/hora y datos típicos de la región
    // Se actualiza con sensación térmica realista. También podemos integrar API pero para mantener offline y demo visual, usamos datos meteorológicos ficticios pero creíbles.
    
    function obtenerClimaSimulado() {
        // Datos climáticos típicos de Nueva Asunción/Chaco Paraguayo: subtropical semiárido, temperaturas cálidas.
        // Simular variación según hora del día y mes
        const now = new Date();
        const mes = now.getMonth(); // 0-11
        const hora = now.getHours();
        
        // Temperaturas base: verano (diciembre-febrero) cálido ~33°C, invierno (junio-agosto) ~22°C máxima.
        let tempBase = 0;
        if (mes >= 11 || mes <= 1) { // verano austral
            tempBase = 32 + Math.sin(hora * Math.PI / 12 - 3) * 4; // pico 36 a las 15hs
        } else if (mes >= 5 && mes <= 7) { // invierno
            tempBase = 20 + Math.sin(hora * Math.PI / 12 - 3) * 3;
        } else {
            tempBase = 27 + Math.sin(hora * Math.PI / 12 - 3) * 4;
        }
        let temperatura = Math.round(tempBase);
        // condiciones posibles: despejado, parcialmente nublado, tormentas aisladas (con baja probabilidad)
        const condiciones = ["Soleado", "Parcialmente nublado", "Nubes dispersas", "Brisa cálida", "Cielo claro"];
        let randomCond = condiciones[Math.floor(Math.random() * condiciones.length)];
        // Para mantener algo de coherencia, cambiar según hora pico: más soleado al mediodía
        if (hora > 10 && hora < 16) randomCond = "Soleado";
        else if (hora > 19) randomCond = "Despejado / Noche cálida";
        
        // humedad típica del chaco
        const humedad = Math.floor(35 + Math.random() * 25);
        
        return {
            temp: temperatura,
            desc: randomCond,
            humedad: humedad,
            ubicacion: "Nueva Asunción, Presidente Hayes"
        };
    }
    
    function actualizarWidgetClima() {
        const clima = obtenerClimaSimulado();
        const tempElement = document.getElementById('weatherTemp');
        const descElement = document.getElementById('weatherDesc');
        const locElement = document.getElementById('weatherLocation');
        const iconElement = document.querySelector('.weather-icon i');
        
        if (tempElement) tempElement.innerText = `${clima.temp}°C`;
        if (descElement) descElement.innerText = `${clima.desc} • ${clima.humedad}% hum.`;
        if (locElement) locElement.innerText = clima.ubicacion;
        // Cambiar ícono según descripción básica
        if (iconElement) {
            const cond = clima.desc.toLowerCase();
            if (cond.includes("soleado") || cond.includes("despejado") || cond.includes("cielo claro"))
                iconElement.className = "fas fa-sun";
            else if (cond.includes("nublado") || cond.includes("nubes"))
                iconElement.className = "fas fa-cloud-sun";
            else if (cond.includes("tormenta") || cond.includes("lluvia"))
                iconElement.className = "fas fa-cloud-rain";
            else
                iconElement.className = "fas fa-cloud-sun";
        }
    }
    
    // ----- Funcionalidad TABS (cambio entre secciones) ----
    function initTabs() {
        const tabs = document.querySelectorAll('.tab-btn');
        const sections = {
            local: document.getElementById('local-section'),
            paraguay: document.getElementById('paraguay-section'),
            mundo: document.getElementById('mundo-section')
        };
        
        tabs.forEach(btn => {
            btn.addEventListener('click', () => {
                const tabId = btn.getAttribute('data-tab');
                if (!tabId || !sections[tabId]) return;
                
                // Actualizar clases activas en botones
                tabs.forEach(bt => bt.classList.remove('active'));
                btn.classList.add('active');
                
                // Ocultar todas las secciones y mostrar la activa
                Object.values(sections).forEach(section => {
                    if (section) section.classList.remove('active-section');
                });
                sections[tabId].classList.add('active-section');
                
                // opcional: scroll suave al inicio del contenido
                window.scrollTo({ top: document.querySelector('.nav-tabs').offsetTop - 10, behavior: 'smooth' });
            });
        });
    }
    
    // Simular actualización del clima cada 30 minutos pero sin recargar agresivo
    let weatherInterval;
    function startWeatherUpdates() {
        actualizarWidgetClima();
        weatherInterval = setInterval(() => {
            actualizarWidgetClima();
        }, 30 * 60 * 1000); // cada 30 min
    }
    
    // Pequeña mejora: Fecha actual en footer de manera dinámica opcional
    function setFooterYear() {
        const footerYear = document.querySelector('.footer p:first-child');
        if (footerYear) {
            const year = new Date().getFullYear();
            footerYear.innerHTML = `<i class="far fa-copyright"></i> ${year} Notilea - Información con compromiso | Nueva Asunción, Presidente Hayes, Paraguay`;
        }
    }
    
    // ---- Inicialización completa ----
    document.addEventListener('DOMContentLoaded', () => {
        cargarTodasLasNoticias();
        initTabs();
        startWeatherUpdates();
        setFooterYear();
        
        // Para mejorar la experiencia en github pages, aseguramos que las imágenes placeholder carguen bien
        // Nota: Se usa placehold.co que es fiable. También podríamos agregar imágenes locales.
        // Además, validar que si hay problemas de red, el texto siga visible.
    });
</script>
